# Uptime Kuma – Docker Compose – beheerd door Ansible
# ====================================================

services:
  uptime-kuma:
    image: louislam/uptime-kuma:1
    container_name: uptime-kuma
    restart: always
    environment:
      - UPTIME_KUMA_BASE_PATH=/status
    ports:
      - "127.0.0.1:3001:3001"
    volumes:
      - /opt/uptime-kuma/data:/app/data
